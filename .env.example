# Pathway Copilot environment variables
#
# The app runs end-to-end WITHOUT a key: when RUNWARE_API_KEY is unset, the
# extractor and drafter fall back to deterministic mocks so the demo works with
# no key. Add a real key to enable live LLM extraction and drafting.
#
# Provider: Runware (https://runware.ai) — a drop-in OpenAI-compatible endpoint.

# Runware API key (optional — leave blank to run in deterministic mock mode).
# Never commit a real key; store it in the secrets manager.
RUNWARE_API_KEY=

# LLM model slug used for extraction and drafting (optional).
# Runware's OpenAI-compatible endpoint uses fully-hyphenated ids of the form
# provider-model-version (e.g. openai-gpt-5-4-mini). List the exact accepted
# ids with: curl https://api.runware.ai/v1/models -H "authorization: Bearer $KEY"
# Default is a cheap, fast, JSON-friendly chat model. NOTE: Gemini models are not
# compatible with our json_object response_format on Runware (they 400), so pick
# an OpenAI model here.
RUNWARE_MODEL=openai-gpt-5-4-mini

# Runware base URL (optional — only override for a proxy / self-host).
# RUNWARE_BASE_URL=https://api.runware.ai/v1
