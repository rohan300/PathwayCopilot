# Pathway Copilot environment variables
#
# The app runs end-to-end WITHOUT a key: when OPENAI_API_KEY is unset, the
# extractor and drafter fall back to deterministic mocks. Add a real key to
# enable live LLM extraction and drafting.

# OpenAI API key (optional — leave blank to run in deterministic mock mode).
OPENAI_API_KEY=

# Model used for extraction and drafting (optional).
OPENAI_MODEL=gpt-4o-mini
